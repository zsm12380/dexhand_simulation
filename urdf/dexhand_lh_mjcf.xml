        <joint range="0 1.5708" axis="-1 0 0" damping="0.5"/>
        <position ctrlrange="0 1.5708" kp="20"/>
      </default>

      <!-- 手指外展 -->
      <default class="finger_abd">
        <joint range="-0.2618 0.2618" axis="1 0 0"/>
        <position ctrlrange="-0.2618 0.2618" kp="10"/>
      </default>

      <!-- 手指弯曲 -->
      <default class="finger_flex">
        <joint range="0 1.5708" axis="-1 0 0" damping="0.5"/>
        <position ctrlrange="0 1.5708" kp="20"/>
      </default>

      <!-- 手腕 FAJ -->
    <default class="wrist">
      <joint range="-0.3491 0.3491" damping="1.0"/>
      <position ctrlrange="-0.3491 0.3491" kp="40"/>
    </default>

      <!-- 线性推杆（滑块） -->
      <default class="linear_rod">
        <joint type="slide" range="-0.02 0.02" damping="2.0"/>
        <position ctrlrange="-0.02 0.02" kp="5000" forcerange="-200 200"/>
      </default>

      <!-- 虚拟连杆/万向杆 -->
      <default class="virtual">
        <joint damping="0.05" armature="0.00005"/>
        <geom contype="0" conaffinity="0"/>   <!-- 通常虚拟杆不参与碰撞 -->
      </default>
    </default>
  </default>



