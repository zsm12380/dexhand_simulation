    <default class="dexhand">
      <joint axis="1 0 0" damping="10" frictionloss="0.4" armature="0.0002"/>
      <geom  solref="0.002 1" solimp="0.95 0.995 0.001"/>
      <position ctrlrange="0 1.5708" forcerange="-10 50" kp="20"/>

      <!-- 拇指基部（THJ4/THJ3） -->
      <default class="thumb_base">
        <joint range="-1.0472 1.0472" axis="1 0 0" damping="0.5"/>
        <position ctrlrange="-1.0472 1.0472" kp="20"/>
      </default>

      <!-- 拇指弯曲（THJ2/THJ1） -->
